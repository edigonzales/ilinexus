TRANSFER INTERLIS1;

MODEL MinimalArea_V1

  DOMAIN
    LKoord = COORD2 2480000.000 1070000.000 2850000.000 1310000.000;
    FlaechenArt = ( Acker, Wiese, Wald);

  TOPIC Boden =

    !! AREA is intentionally used here, not SURFACE.
    !! In INTERLIS 1 ITF this implies a geometry helper/line table.
    !! The helper table records must appear before the main table records in raw ITF.
    !! Shared boundaries between adjacent area objects must be represented only once.
    TABLE Bodenbedeckung =
      Art: FlaechenArt;
      Geometrie: AREA WITH (STRAIGHTS, ARCS) VERTEX LKoord WITHOUT OVERLAPS > 0.050;
      IDENT Geometrie;
    END Bodenbedeckung;

  END Boden.

END MinimalArea_V1.
