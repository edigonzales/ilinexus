TRANSFER INTERLIS1;

MODEL MinimalPoint_V1

  DOMAIN
    LKoord = COORD2 2480000.000 1070000.000 2850000.000 1310000.000;
    Genauigkeit = [0.0 .. 700.0];
    JaNein = ( ja, nein);

  TOPIC Fixpunkte =

    TABLE Nachfuehrung =
      NBIdent: TEXT*12;
      Identifikator: TEXT*12;
      Beschreibung: OPTIONAL TEXT*30;
      GueltigerEintrag: OPTIONAL DATE;
      IDENT NBIdent, Identifikator;
    END Nachfuehrung;

    TABLE Punkt =
      Entstehung: -> Nachfuehrung;
      NBIdent: TEXT*12;
      Nummer: TEXT*12;
      Geometrie: LKoord;
      LageGen: Genauigkeit;
      LageZuv: JaNein;
      IDENT NBIdent, Nummer;
      Geometrie;
    END Punkt;

  END Fixpunkte.

END MinimalPoint_V1.
