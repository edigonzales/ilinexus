TRANSFER INTERLIS1;

MODEL MinimalSurface_V1

  DOMAIN
    LKoord = COORD2 2480000.000 1070000.000 2850000.000 1310000.000;

  TOPIC Data =

    TABLE Flaeche =
      Name: TEXT*30;
      Geometrie: SURFACE WITH (STRAIGHTS, ARCS) VERTEX LKoord WITHOUT OVERLAPS > 0.050;
      NO IDENT
    END Flaeche;

  END Data.

END MinimalSurface_V1.
